# Copy to .env on the server (do not commit .env)
# Each service uses its own DB_URL pointing to its database.

# --- auth-service (port 8081, database: users_db) ---
# SPRING_PROFILES_ACTIVE=prod
# DB_URL=jdbc:mysql://localhost:3306/users_db?useSSL=true
# DB_USER=your_user
# DB_PASSWORD=your_password
# JWT_SECRET=generate-a-long-random-string-here

# --- booking-service (port 8082, database: bookings_db) ---
# DB_URL=jdbc:mysql://localhost:3306/bookings_db?useSSL=true
# DB_USER=your_user
# DB_PASSWORD=your_password

# --- destination-service (port 8083, database: destinations_db) ---
# DB_URL=jdbc:mysql://localhost:3306/destinations_db?useSSL=true
# DB_USER=your_user
# DB_PASSWORD=your_password

# --- packages-service (port 8084, database: packages_db) ---
# DB_URL=jdbc:mysql://localhost:3306/packages_db?useSSL=true
# DB_USER=your_user
# DB_PASSWORD=your_password
